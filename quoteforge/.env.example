# ─── QuoteForge Environment Variables ───
# Copy this file to .env and fill in your values

# API Base URL (your FastAPI / Django backend)
VITE_API_BASE_URL=http://localhost:8000/api/v1

# CRM OAuth Credentials
VITE_SALESFORCE_CLIENT_ID=your_salesforce_client_id
VITE_HUBSPOT_CLIENT_ID=your_hubspot_client_id

# AI Service
VITE_AI_SERVICE_URL=http://localhost:8000/api/v1/ai

# App Settings
VITE_APP_NAME=QuoteForge
VITE_APP_VERSION=1.0.0
