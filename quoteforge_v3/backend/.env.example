# QuoteForge V3 backend environment variables.
# Copy this file to .env and fill in real values. .env is gitignored.

# ─── Core ──────────────────────────────────────────────────────────────
DATABASE_URL=
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ─── AI providers ──────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2000

# ─── Email (SMTP) ──────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ─── CRM OAuth ─────────────────────────────────────────────────────────
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
# login.salesforce.com for prod orgs, test.salesforce.com for sandboxes.
SALESFORCE_LOGIN_URL=https://login.salesforce.com
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# ─── One-click Connected App flow ──────────────────────────────────────
# Public HTTPS URL the backend is reachable at (no trailing slash). Used
# to build the OAuth callback URL passed to Salesforce, and the post-
# consent redirect. Render sets this automatically via render.yaml.
PUBLIC_BASE_URL=
# Fernet key for encrypting Salesforce OAuth tokens at rest. Generate
# with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# REQUIRED for any real deploy — local dev falls back to an ephemeral
# key that invalidates on restart.
TOKEN_ENCRYPTION_KEY=
# Comma-separated origin allowlist for CORS. Empty = wide-open "*" for
# local dev. Salesforce Lightning hosts are matched by regex in
# app/core/cors.py so they don't need to be listed here.
CORS_ALLOW_ORIGINS=

# ─── ML / negotiation backend ──────────────────────────────────────────
MLX_BASE_MODEL=
MLX_ADAPTER_PATH=
# Master switch for proposal-section text generation. When "true", routes
# through the configured LLM_BACKEND (mlx / ollama / openai). When "false"
# or unset, ai_service falls back to deterministic templates — preferred
# for demos because the v1 local model (Llama 3.2 1B 4-bit) leaks
# chat-template tokens and loops in pricing sections. See README "Known
# Limitations" + docs/v2_spec.md for the v2 plan.
QUOTEFORGE_USE_LLM=false
LLM_BACKEND=
INSIGHTS_REAL_DATA_PATH=
# Kill switch for the nightly Deal Insights retrain cron. Set to "true" to
# stop the scheduler from registering its 02:00 UTC job. Manual training
# paths (POST /api/insights/train, admin wizard) are NOT gated by this.
INSIGHTS_TRAIN_DISABLED=

# ─── Test credentials (used by backend/tests/test_tenant_isolation.py) ─
# Real values must NEVER be committed. Populate locally only.
QF_TEST_DEFAULT_PASSWORD=
QF_TEST_TENANT_PASSWORD=

# ─── Default seeded passwords ──────────────────────────────────────────
# Used by app/seed.py on first launch to hash the passwords for the seeded
# default-tenant users. Both fall back to "change-me-locally" if unset
# (so the backend still boots), but you MUST set these for any real deploy.
QF_DEFAULT_ADMIN_PASSWORD=
QF_DEFAULT_USER_PASSWORD=

# ─── Salesforce tenant config (Prod + Sandbox) ─────────────────────────
# Substituted into customMetadata XML by scripts/deploy_metadata.sh.
QF_PROD_TENANT_PASSWORD=
QF_SANDBOX_TENANT_PASSWORD=
