# ─── QuoteForge Environment Variables ────────────────────────────────
# Copy this file to .env.local and fill in your values.

# Backend API URL (leave empty for Vite proxy in development)
VITE_API_BASE_URL=

# CRM OAuth Credentials (used by backend, not frontend)
# SALESFORCE_CLIENT_ID=
# SALESFORCE_CLIENT_SECRET=
# HUBSPOT_CLIENT_ID=
# HUBSPOT_CLIENT_SECRET=

# AI Service
# OPENAI_API_KEY=
