<?xml version="1.0" encoding="UTF-8"?>
<!--
    Named Credential — backing for `callout:QuoteForge_API` in Apex.

    The endpoint is the public QuoteForge backend URL. Apex never has to
    hardcode it; rotating the tunnel (or moving to a new Render service)
    is a one-field change in Setup → Named Credentials.

    BEFORE DEPLOY: replace `YOUR-RENDER-SERVICE.onrender.com` with the
    actual hostname. The backend handles its own JWT auth on /auth/login,
    so the Named Credential itself uses NoAuthentication — Apex sends the
    Bearer token in the request manually (see QuoteForgeController.cls).
-->
<NamedCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>QuoteForge API</label>
    <endpoint>https://YOUR-RENDER-SERVICE.onrender.com</endpoint>
    <principalType>Anonymous</principalType>
    <protocol>NoAuthentication</protocol>
    <generateAuthorizationHeader>false</generateAuthorizationHeader>
</NamedCredential>
